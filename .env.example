# Google Gemini API key (required)
GOOGLE_API_KEY=your_google_api_key_here

# ChromaDB settings
CHROMA_DB_DIR=./chroma_db
CHROMA_COLLECTION_NAME=documents

# Chunk settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# LLM settings
LLM_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-001
